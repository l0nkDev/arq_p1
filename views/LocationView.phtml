    <script>
        let batchDraft = [];
        const rawData = <?= json_encode($data) ?>;

        function toggleBatchMode() {
            const type = document.getElementById('batch-type').value;
            const parentSelect = document.getElementById('temp-parent-id');
            parentSelect.innerHTML = '';
            batchDraft = [];
            updateUI();

            if (type === 'room') {
                document.getElementById('label-number').innerText = 'Número de Aula';
                document.getElementById('label-parent').innerText = 'Módulo Padre';
                rawData.forEach(entry => {
                    if (entry.Module && !entry.Room) {
                        let opt = document.createElement('option');
                        opt.value = entry.Location_id;
                        opt.text = `${entry.Precinct} - Mód. ${entry.Module}`;
                        parentSelect.add(opt);
                    }
                });
            } else {
                document.getElementById('label-number').innerText = 'Número de Módulo';
                document.getElementById('label-parent').innerText = 'Predio Padre';
                rawData.forEach(entry => {
                    if (entry.Precinct && !entry.Module && !entry.Room) {
                        let opt = document.createElement('option');
                        opt.value = entry.Location_id;
                        opt.text = entry.Precinct;
                        parentSelect.add(opt);
                    }
                });
            }
        }

        function addToBatch() {
            const number = document.getElementById('temp-number').value;
            const parentId = document.getElementById('temp-parent-id').value;
            if (!number || !parentId) return;

            const parentText = document.getElementById('temp-parent-id').options[document.getElementById('temp-parent-id').selectedIndex].text;

            batchDraft.push({ number: number, parent_id: parentId, parent_name: parentText });
            updateUI();
            
            // UX Improvement: Clear input and focus back on it for rapid typing
            document.getElementById('temp-number').value = '';
            document.getElementById('temp-number').focus(); 
        }

        function updateUI() {
            const list = document.getElementById('visual-draft-list');
            const type = document.getElementById('batch-type').value;
            list.innerHTML = '';
            
            batchDraft.forEach(item => {
                let li = document.createElement('li');
                li.className = 'list-group-item d-flex justify-content-between align-items-center py-1 px-2 small bg-white';
                li.innerHTML = `<span><b>${type === 'room' ? 'Aula' : 'Mód.'} ${item.number}</b> <span class="text-muted">en ${item.parent_name}</span></span>`;
                list.appendChild(li);
            });

            document.getElementById('batch-data-input').value = JSON.stringify(batchDraft);
            document.getElementById('batch-type-hidden').value = type;
            document.getElementById('submit-batch').disabled = batchDraft.length === 0;
        }

        window.onload = toggleBatchMode;
    </script>
</body>
</html>